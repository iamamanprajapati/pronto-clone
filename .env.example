# apps/api reads apps/api/.env — copy this there
DATABASE_URL=postgresql://pronto:pronto@localhost:5432/pronto
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-production
PORT=4000
# Payments: "mock" runs a simulated gateway; set "razorpay" + keys for real
PAYMENT_PROVIDER=mock
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Notifications: "log" stores + logs; set FCM/MSG91 creds for real delivery
NOTIFY_PROVIDER=log
FCM_SERVER_KEY=
MSG91_AUTH_KEY=
# Dev convenience: OTP for any phone in dev mode
DEV_STATIC_OTP=123456
