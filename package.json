{
  "name": "pronto-clone",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "api": "pnpm --filter @pronto/api dev",
    "admin": "pnpm --filter @pronto/admin dev",
    "customer": "pnpm --filter @pronto/customer start",
    "worker": "pnpm --filter @pronto/worker start",
    "db:push": "pnpm --filter @pronto/api db:push",
    "db:seed": "pnpm --filter @pronto/api db:seed",
    "typecheck": "pnpm -r typecheck"
  },
  "packageManager": "pnpm@11.2.2"
}
